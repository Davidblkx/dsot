{
    "fmt": {
        "indentWidth": 4
    },
    "tasks": {
        "tauri-dev": "PLATFORM_MODE=tauri tauri dev"
    },
    "compilerOptions": {
        "allowJs": true,
        "checkJs": true,
        "skipLibCheck": true,
        "strict": true,
        "moduleResolution": "bundler",
        "module": "esnext",
        "types": [],
        "jsx": "preserve",
        "jsxFactory": "h",
        "jsxFragmentFactory": "Fragment",
        "jsxImportSource": "npm:vue"
    },
    "imports": {
        "$platform": "./src/platform/typings.d.ts",
        "$pmodel/": "./src/platform/model/",
        "$css/": "./css/",
        "$infra/": "./src/infra/"
    }
}
